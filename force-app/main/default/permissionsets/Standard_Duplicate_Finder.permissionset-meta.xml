<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Standard Duplicate Finder</label>
    <description>Access for Standard Duplicate Finder (Contacts &amp; Leads).</description>

    <classAccesses>
        <apexClass>StandardDuplicateFinderController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>DupFinderNormalize</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <tabSettings>
        <tab>Standard_Duplicate_Finder</tab>
        <visibility>Visible</visibility>
    </tabSettings>

    <!-- Read-only: users must already have permissions to view these objects/fields -->
    <objectPermissions>
        <object>Contact</object>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Lead</object>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <hasActivationRequired>false</hasActivationRequired>
</PermissionSet>
